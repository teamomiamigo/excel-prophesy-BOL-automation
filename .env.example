# =============================================================================
# SG360 BOL Reconciliation — environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# =============================================================================

# --- Core mode flag — REQUIRED for Stage 1 (mock mode) ---
USE_MOCK_DATA=True
MOCK_INVOICES=True

# --- App metadata — safe defaults, rarely need changing ---
APP_NAME=SG360 BOL Reconciliation
APP_VERSION=1.0.0
DEBUG=True

# --- CORS — comma-separated list consumed as a JSON-style list by pydantic-settings ---
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# =============================================================================
# Everything below this line is ONLY required when USE_MOCK_DATA=False
# (live mode — OUT OF SCOPE for Stage 1). Leave as-is / blank for Stage 1.
# =============================================================================

# --- PostgreSQL (live mode only) ---
DATABASE_URL=postgresql://sg360_user:changeme@localhost:5432/sg360_bol

# --- AWP-SQL-PROD SQL Server (live mode only; blank = Windows auth) ---
SQLSERVER_USER=
SQLSERVER_PASSWORD=

# --- EIA diesel price API (live mode only; free key from eia.gov/developer) ---
EIA_API_KEY=

# --- SMTP / outbound email (live mode only) ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=user@sg360.com
SMTP_PASSWORD=
EMAIL_FROM=logistics@sg360.com
EMAIL_TO_MARY=["mary@sg360.com"]
EMAIL_TO_KATIE=["katie@sg360.com"]
EMAIL_SUBJECT_PREFIX=BOL Approvals —

# --- IMAP inbox polling for ALG invoices (live mode only) ---
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_MAILBOX=INBOX
ALG_SENDER_EMAIL=

# --- Invoice watch folder (live mode only; blank = disabled) ---
INVOICE_FOLDER=
